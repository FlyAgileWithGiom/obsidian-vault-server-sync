{
  "name": "mac-vault-sync",
  "version": "1.0.0",
  "description": "Lightweight CouchDB sync for Obsidian vaults",
  "main": "main.js",
  "bin": {
    "vault-sync-daemon": "dist/headless.js"
  },
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "build:headless": "node -e \"import('./esbuild.config.mjs')\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.4.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {}
}
